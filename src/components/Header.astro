---
const navLinks = [
  { label: 'ホーム', href: '/' },
  { label: '記事一覧', href: '/articles' },
  { label: 'アプリ比較', href: '/articles/category/ranking' },
  { label: '使い方ガイド', href: '/articles/category/howto' },
  { label: 'よくある質問', href: '/articles/category/faq' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo" aria-label="トップページへ">
      <span class="logo-text">💑 50代マッチング完全ガイド</span>
      <span class="logo-sub">50代男性のための出会い・再婚サポート情報</span>
    </a>
    <nav class="site-nav" aria-label="メインナビゲーション">
      <ul>
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
